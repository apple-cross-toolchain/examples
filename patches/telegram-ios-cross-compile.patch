+            "ORDERED_SYMBOLS": ["dyld_stub_binder", "__mh_execute_header", "_main", "_dontCallMeMain", "_anotherFunctionMain"],
+        },
+        tags = [name],
+        timeout = "short",
+        compilation_mode = "opt",
